<?xml version='1.0' encoding='utf-8'?>
<!--
  Approximate URDF for Seeed Studio reBot B601-DM (7-DOF, Damiao motors)
  650mm max reach.  No mesh files — uses primitive geometry for PyBullet IK/FK.

  Joint chain:
    shoulder_pan  (Z)  → shoulder_lift (Y) → elbow_flex (Y) → wrist_flex (Y)
    → wrist_yaw   (Z)  → wrist_roll    (X) → gripper    (Y) → [fixed] rebot_tip

  Link lengths (shoulder_lift pivot → tip = 0.65 m):
    upper_arm  0.285 m
    lower_arm  0.215 m
    wrist      0.060 m
    wrist_yaw  0.040 m
    wrist_roll 0.025 m
    gripper    0.025 m  (tip offset)
-->
<robot name="rebot_b601_dm">

  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="light_grey">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>

  <!-- ================================================================ -->
  <!-- Links                                                              -->
  <!-- ================================================================ -->

  <link name="base">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.08"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.08"/></geometry>
    </collision>
  </link>

  <link name="shoulder">
    <inertial>
      <mass value="0.4"/>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.02"/></geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.02"/></geometry>
    </collision>
  </link>

  <link name="upper_arm">
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0 0 0.1425" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.1425" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.285"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.1425" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.285"/></geometry>
    </collision>
  </link>

  <link name="lower_arm">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0.1075" rpy="0 0 0"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.1075" rpy="0 0 0"/>
      <geometry><cylinder radius="0.022" length="0.215"/></geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.1075" rpy="0 0 0"/>
      <geometry><cylinder radius="0.022" length="0.215"/></geometry>
    </collision>
  </link>

  <link name="wrist">
    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.06"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.06"/></geometry>
    </collision>
  </link>

  <link name="wrist_yaw_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><cylinder radius="0.016" length="0.04"/></geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><cylinder radius="0.016" length="0.04"/></geometry>
    </collision>
  </link>

  <link name="wrist_roll_link">
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0 0 0.0125" rpy="0 0 0"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00003"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.0125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.014" length="0.025"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.014" length="0.025"/></geometry>
    </collision>
  </link>

  <link name="gripper_link">
    <inertial>
      <mass value="0.06"/>
      <origin xyz="0 0 0.0125" rpy="0 0 0"/>
      <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00002"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.0125" rpy="0 0 0"/>
      <geometry><box size="0.04 0.02 0.025"/></geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0125" rpy="0 0 0"/>
      <geometry><box size="0.04 0.02 0.025"/></geometry>
    </collision>
  </link>

  <!-- Massless tip link for IK target -->
  <link name="rebot_tip"/>

  <!-- ================================================================ -->
  <!-- Joints                                                             -->
  <!-- ================================================================ -->

  <!-- Joint 0 – shoulder_pan: yaw around Z, mounted on top of base.
       Axis sign flipped (-Z) to match the physical motor's positive
       rotation direction — the IK joint angle now matches the angle
       sent to / read from the real Damiao motor. -->
  <joint name="shoulder_pan" type="revolute">
    <parent link="base"/>
    <child link="shoulder"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-2.531" upper="2.531" effort="40" velocity="2.0"/>
  </joint>

  <!-- Joint 1 – shoulder_lift: pitch around X.
       Axis sign flipped (-X) to match the physical motor's positive
       rotation direction. With this convention: at θ=0 arm points +Z
       (up); at θ=-90° arm points -Y (toward the base). The numeric
       limit range is unchanged — only the geometric direction it maps
       to is corrected. -->
  <joint name="shoulder_lift" type="revolute">
    <parent link="shoulder"/>
    <child link="upper_arm"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-2.967" upper="0.017" effort="80" velocity="2.0"/>
  </joint>

  <!-- Joint 2 – elbow_flex: pitch around X (same sagittal plane as shoulder_lift).
       Axis sign flipped (-X) for the same reason as shoulder_lift. -->
  <joint name="elbow_flex" type="revolute">
    <parent link="upper_arm"/>
    <child link="lower_arm"/>
    <origin xyz="0 0 0.285" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-3.491" upper="0.017" effort="40" velocity="2.0"/>
  </joint>

  <!-- Joint 3 – wrist_flex: pitch around X (same sagittal plane) -->
  <joint name="wrist_flex" type="revolute">
    <parent link="lower_arm"/>
    <child link="wrist"/>
    <origin xyz="0 0 0.215" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.396" upper="1.571" effort="20" velocity="3.0"/>
  </joint>

  <!-- Joint 4 – wrist_yaw: yaw around Z (reBot extra DOF vs SO100) -->
  <joint name="wrist_yaw" type="revolute">
    <parent link="wrist"/>
    <child link="wrist_yaw_link"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.571" upper="1.571" effort="15" velocity="3.0"/>
  </joint>

  <!-- Joint 5 – wrist_roll: roll around Y (along arm axis when shoulder_lift=-90°) -->
  <joint name="wrist_roll" type="revolute">
    <parent link="wrist_yaw_link"/>
    <child link="wrist_roll_link"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.571" upper="1.571" effort="15" velocity="3.0"/>
  </joint>

  <!-- Joint 6 – gripper: pinch motion around Y -->
  <joint name="gripper" type="revolute">
    <parent link="wrist_roll_link"/>
    <child link="gripper_link"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-4.712" upper="0.0" effort="10" velocity="2.0"/>
  </joint>

  <!-- Fixed tip: IK end-effector target point -->
  <joint name="rebot_tip_joint" type="fixed">
    <parent link="gripper_link"/>
    <child link="rebot_tip"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
  </joint>

</robot>
